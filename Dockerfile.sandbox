FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pytest bandit safety

RUN useradd -m -u 1000 viki && \
    mkdir /workspace && \
    chown viki:viki /workspace

USER viki
WORKDIR /workspace

CMD ["sleep", "3600"]
